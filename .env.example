# Environment Variables - NEVER commit this file!
# Add to .gitignore
#
# The application no longer contains any hard-coded Supabase credentials.
# You *must* supply your own project URL and anon key before running the app.

# Supabase Configuration (Vite expects VITE_ prefix)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
# service key should never be exposed to client, store safely on server
# VITE_SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY_HERE

# Environment
NODE_ENV=development
DEBUG=true

# Get these values from:
# 1. Go to Supabase dashboard
# 2. Settings → API
# 3. Copy Project URL and keys
